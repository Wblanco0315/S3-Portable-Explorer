{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "s3explorer",
  "version": "1.0.1",
  "identifier": "com.wposs.s3explorer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "s3explorer",
        "width": 1000,
        "height": 750
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "nsis"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFEM0EwQTg1MEJEMDIwMDIKUldRQ0lOQUxoUW82clY3azJzK1htRVJEZ3Y1SU02ckJYeUpXQy9DT1UvOHZSaE9MRnlQTFI1WWIK",
      "endpoints": [
        "https://github.com/Wblanco0315/S3-Portable-Explorer/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}