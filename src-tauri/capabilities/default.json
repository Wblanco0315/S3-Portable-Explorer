{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "dialog:default",
    "fs:default",
    "sql:default",
    "sql:allow-execute",
    "http:default",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-write-text-file",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://**.amazonaws.com"
        },
        {
          "url": "https://**.amazonaws.com/*"
        },
        {
          "url": "https://*.s3.*.amazonaws.com/*"
        },
        {
          "url": "https://s3.*.amazonaws.com/*"
        },
        {
          "url": "https://*.s3.amazonaws.com/*"
        }
      ]
    },
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "aws",
          "cmd": "aws",
          "args": true
        },
        {
          "name": "cmd",
          "cmd": "cmd",
          "args": true
        },
        {
          "name": "osascript",
          "cmd": "osascript",
          "args": true
        }
      ]
    },
    "notification:default"
  ]
}